# Required: API key UUID from Kalshi dashboard
KALSHI_ACCESS_KEY_ID=

# Required: path to PEM private key (matches registered public key)
KALSHI_PRIVATE_KEY_PATH=

# Demo (default). Production: https://api.elections.kalshi.com/trade-api/v2
KALSHI_REST_BASE=https://demo-api.kalshi.co/trade-api/v2

# Demo WebSocket (default)
KALSHI_WS_URL=wss://demo-api.kalshi.co/trade-api/ws/v2

# Default: true — log RFQs, never submit quotes
KALSHI_DRY_RUN=true

# Must be true to call POST /communications/quotes (use with DRY_RUN=false)
KALSHI_QUOTE_ENABLED=false

# noop | fixed — noop never prices; fixed uses env bids below
KALSHI_STRATEGY=noop

# Only if STRATEGY=fixed and quoting enabled: dollar strings e.g. 0.48 / 0.52
KALSHI_FIXED_YES_BID=
KALSHI_FIXED_NO_BID=

# Optional: communications channel sharding (1-100)
# KALSHI_COMM_SHARD_FACTOR=
# KALSHI_COMM_SHARD_KEY=
